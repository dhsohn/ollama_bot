# 텔레그램 봇 토큰 (BotFather에서 발급)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 허용된 텔레그램 사용자 ID (쉼표 구분)
ALLOWED_TELEGRAM_USERS=your_telegram_chat_id_here

# (선택) ORCA 지식베이스 호스트 루트 경로
# 기본값: ./kb (즉, ./kb/orca_runs, ./kb/orca_outputs)
HOST_KB_DIR=./kb

# (선택) 시뮬레이션 입력 shorthand 기본 경로
# 예: /sim submit orca_auto STRUC1  -> ${SIM_INPUT_DIR_ORCA_AUTO}/STRUC1 로 해석
SIM_INPUT_DIR_ORCA_AUTO=/app/kb/orca_runs
# (선택) 모든 시뮬레이션 도구 공통 기본 경로
# SIM_INPUT_DIR=/app/kb/sim_inputs
