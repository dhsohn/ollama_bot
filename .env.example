# 텔레그램 봇 토큰 (BotFather에서 발급)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 허용된 텔레그램 사용자 ID (쉼표 구분)
ALLOWED_TELEGRAM_USERS=your_telegram_chat_id_here

# 로그 레벨
LOG_LEVEL=INFO

# 자동화 스케줄 타임존
SCHEDULER_TIMEZONE=Asia/Seoul

# LLM provider (ollama | lemonade)
LLM_PROVIDER=ollama

# Ollama 서버 주소 (WSL2에서는 host.docker.internal 사용)
OLLAMA_HOST=http://host.docker.internal:11434

# 기본 모델
OLLAMA_MODEL=gpt-oss:20b

# 데이터 디렉토리
DATA_DIR=/app/data

# Lemonade(OpenAI-compatible) 서버 설정
LEMONADE_HOST=http://host.docker.internal:8000
LEMONADE_MODEL=
LEMONADE_API_KEY=
LEMONADE_BASE_PATH=/api/v1
LEMONADE_TIMEOUT_SECONDS=60

# AMD NPU 프로파일 (선택): balanced | throughput | latency
AMD_NPU_PROFILE=balanced
