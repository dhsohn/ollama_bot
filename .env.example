# 텔레그램 봇 토큰 (BotFather에서 발급)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 허용된 텔레그램 사용자 ID (쉼표 구분)
ALLOWED_TELEGRAM_USERS=your_telegram_chat_id_here

# (선택) 시뮬레이션 입력 shorthand 기본 경로
# 예: /sim submit orca_auto mj1  ->  ${SIM_INPUT_DIR_ORCA_AUTO}/mj1 로 해석
SIM_INPUT_DIR_ORCA_AUTO=kb/orca_runs

# 시뮬레이션 호스트 에이전트 인증 토큰 (필수)
SIM_EXTERNAL_AGENT_TOKEN=change_this_to_a_long_random_token

# (선택) orca_auto 실행 파일 경로
# SIM_TOOL_EXECUTABLE_ORCA_AUTO=~/orca_auto/bin/orca_auto

# (선택) ORCA 바이너리 경로
# ORCA_AUTO_ORCA_EXECUTABLE=~/opt/orca/orca
