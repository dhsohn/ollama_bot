# 텔레그램 봇 토큰 (BotFather에서 발급)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 허용된 텔레그램 사용자 ID (쉼표 구분)
ALLOWED_TELEGRAM_USERS=your_telegram_chat_id_here

# (선택) ORCA 지식베이스 호스트 루트 경로
# 기본값: ./kb (즉, ./kb/orca_runs, ./kb/orca_outputs)
HOST_KB_DIR=./kb

# (선택) host ORCA 바이너리 디렉터리
# 기본값: /home/daehyupsohn/opt/orca (컨테이너 내 /app/host/orca_bin 로 마운트)
# ORCA_HOST_DIR=/home/daehyupsohn/opt/orca

# (선택) 시뮬레이션 입력 shorthand 기본 경로
# 예: /sim submit orca_auto STRUC1  -> ${SIM_INPUT_DIR_ORCA_AUTO}/STRUC1 로 해석
SIM_INPUT_DIR_ORCA_AUTO=/app/kb/orca_runs
# (선택) 모든 시뮬레이션 도구 공통 기본 경로
# SIM_INPUT_DIR=/app/kb/sim_inputs

# 외부 시뮬레이션 호스트 에이전트 인증 토큰(필수)
SIM_EXTERNAL_AGENT_TOKEN=change_this_to_a_long_random_token

# (선택) 호스트 에이전트 실행 UID/GID
# 외부 시뮬레이션 프로세스와 동일한 사용자 권한(예: 1000:1000)으로 맞추는 것을 권장
# SIM_AGENT_UID=1000
# SIM_AGENT_GID=1000
