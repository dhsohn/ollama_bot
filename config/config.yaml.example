# ollama_bot 전역 설정
log_level: "INFO"
data_dir: "data"
strict_startup: false

bot:
  name: "ollama_bot"
  language: "ko"                    # default UI language: "ko" | "en"
  max_conversation_length: 15
  response_timeout: 300

telegram:
  bot_token: "your_telegram_bot_token_here"
  allowed_users: "your_telegram_chat_id_here"
  polling_interval: 1
  max_message_length: 4096

security:
  allowed_users: []
  rate_limit: 30
  max_concurrent_requests: 2
  max_input_length: 10000
  max_file_size: 10485760
  blocked_paths:
    - "/etc/*"
    - "/proc/*"
    - "/sys/*"

memory:
  backend: "sqlite"
  max_long_term_entries: 1000
  conversation_retention_days: 30

runtime_maintenance:
  memory_maintenance_interval_seconds: 21600  # 6시간
  llm_recovery_interval_seconds: 60
  memory_maintenance_jitter_ratio: 0.1

scheduler:
  timezone: "Asia/Seoul"

feedback:
  enabled: true
  show_buttons: true
  min_feedback_for_analysis: 5
  max_guidelines: 5
  preview_max_chars: 300
  preview_cache_max_size: 500
  preview_cache_ttl_hours: 24
  retention_days: 90
  collect_reason: true
  reason_min_chars: 3
  reason_max_chars: 500
  reason_timeout_seconds: 120
  dicl_enabled: true
  dicl_max_examples: 1
  dicl_max_keywords: 5
  dicl_max_total_chars: 1200
  dicl_recent_days: 180

instant_responder:
  enabled: true
  rules_path: "config/instant_rules.yaml"

semantic_cache:
  enabled: true
  model_name: "sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2"
  similarity_threshold: 0.96
  min_query_chars: 6
  exclude_patterns:
    - "(지금|현재)\\s*몇\\s*시"
    - "오늘\\s*(날짜|며칠|요일)"
  max_entries: 2000
  ttl_hours: 168
  invalidate_on_negative_feedback: true

intent_router:
  enabled: true
  routes_path: "config/intent_routes.yaml"
  min_confidence: 0.75
  encoder_model: "sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2"

context_compressor:
  enabled: true
  recent_keep: 5
  summary_refresh_interval: 10
  summary_max_tokens: 200
  background_summarize: false
  summarize_concurrency: 1

response_planner:
  enabled: true
  min_input_chars: 80
  trigger_intents:
    - "complex"
    - "code"
  force_for_rag: false
  max_plan_tokens: 256
  timeout_seconds: 45
  max_sections: 4
  max_must_cover: 4

response_reviewer:
  enabled: true
  only_when_planner_used: true
  max_review_tokens: 384
  timeout_seconds: 45
  stream_buffering: true

# ── Ollama: chat + retrieval ──

ollama:
  host: "http://localhost:11434"
  prompt_version: "v1"
  embedding_model: "dengcao/Qwen3-Embedding-0.6B:Q8_0"
  reranker_model: "dengcao/bge-reranker-v2-m3:latest"
  chat_model: "gpt-oss:20b"
  # chat_temperature: 0.7
  # chat_max_tokens: 4096
  # chat_num_ctx: 8192
  # chat_system_prompt: |
  #   You are a helpful AI assistant.

rag:
  enabled: true
  startup_index_enabled: true
  kb_dirs:
    - "./kb"
  max_file_size_mb: 5
  trigger_keywords:
    - "결과"
  chunk_min_tokens: 400
  chunk_max_tokens: 900
  chunk_overlap_ratio: 0.15
  retrieve_k0: 40
  rerank_enabled: true
  rerank_topk: 6
  rerank_budget_ms: 1200
  retrieval_score_floor: 0.25
  supported_extensions:
    - ".md"
    - ".json"
    - ".py"
    - ".js"
    - ".ts"
    - ".txt"
    - ".yaml"
    - ".yml"
    - ".cfg"
    - ".ini"
    - ".toml"
    - ".sh"
    - ".out"
    - ".log"
